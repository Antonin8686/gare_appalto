# Copia questo file in scripts/deploy.config.ps1 e compila i valori.
# deploy.config.ps1 è in .gitignore — le password NON vanno su GitHub.

# IP del nuovo VPS Ionos
$VpsHost = ""

# Utente SSH (di solito root su Ionos)
$VpsUser = "root"

# Password SSH root Ionos (obbligatoria per deploy automatico senza prompt)
$VpsSshPassword = ""

# Cartella sul server
$VpsPath = "/var/www/gare-appalto"
$ComposeProjectName = "gareappalto"

# Dominio puntato al VPS (record A). Se non hai dominio, usa l'IP.
$AppDomain = ""

# URL pubblico del sito
$SiteUrl = ""

# true = VPS dedicato solo a Gare Appalto (porte 80/443)
$DedicatedVps = $true

# Branch da pubblicare sul VPS (deve esistere su origin)
$GitBranch = "introduzione-ai-offerta.tecnica"
